{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/v2/crates/tauri-utils/schema/capability.json",
  "identifier": "default",
  "description": "Default capabilities for Glyph",
  "windows": ["main", "w*"],
  "permissions": [
    "core:default",
    "core:app:allow-set-app-theme",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "dialog:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "os:default",
    "store:default",
    "opener:default",
    "opener:allow-reveal-item-in-dir"
  ]
}
