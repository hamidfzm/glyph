{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/v2/crates/tauri-utils/schema/capability.json",
  "identifier": "default",
  "description": "Default capabilities for Glyph",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-read-text-file",
    "os:default",
    "cli:default",
    "cli:allow-cli-matches",
    "window-state:default"
  ]
}
